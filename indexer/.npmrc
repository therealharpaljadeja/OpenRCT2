# Hoist all transitive deps into the root node_modules so the rescript-compiled
# generated/index.js can require() things like @envio-dev/hypersync-client without
# them being declared in generated/package.json. Without this, pnpm's strict
# isolated layout traps those packages inside .pnpm/ and the indexer crashes at
# handler-load time with `Cannot find module '@envio-dev/hypersync-client'`.
shamefully-hoist=true
