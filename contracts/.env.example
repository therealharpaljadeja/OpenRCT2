# Monad testnet RPC + chain config.
# Default public endpoint; override if you have a higher-rate-limit provider.
MONAD_TESTNET_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_TESTNET_CHAIN_ID=10143

# Block explorer (Monadscan, served via the Etherscan v2 multichain API).
# API key obtainable at https://etherscan.io/myapikey — works across v2-supported chains.
MONAD_EXPLORER_URL=https://testnet.monadscan.com
MONAD_EXPLORER_API_URL=https://api.etherscan.io/v2/api?chainid=10143
MONAD_EXPLORER_API_KEY=

# Deployer key. Funded with MON on testnet.
# Never check this in. The .env file is gitignored.
DEPLOYER_PRIVATE_KEY=0xCHANGEME
